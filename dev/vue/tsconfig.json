{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "preserve",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "useDefineForClassFields": true,
        "types": ["vite/client"]
    },
    "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
