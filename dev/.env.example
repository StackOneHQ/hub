# Shared by the Vite sandboxes (vue, svelte, react) via `envDir: '..'` in each vite.config.ts.
# Copy to `dev/.env` and fill in to enable token auto-fetch. Leave blank to use the paste input.
# NOTE: the Angular sandbox does not read this file — set its values in
# dev/angular/src/environments/environment.ts instead.
VITE_STACKONE_API_KEY=
VITE_API_URL=https://api.stackone.com
VITE_ORIGIN_OWNER_ID=dummy_customer_id
VITE_ORIGIN_OWNER_NAME=dummy_customer_name
VITE_ORIGIN_USERNAME=dummy_customer_username
